---
// Stitch Generated Solutions Component
---

<section class="py-24 relative" id="services">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <h2 class="text-4xl font-extrabold text-slate-900 dark:text-white mb-6" data-i18n="solutions.title">
          Software a medida para desafíos globales
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-400 mb-8 leading-relaxed" data-i18n="solutions.desc">
          No solo escribimos código, construimos soluciones tecnológicas robustas que escalan. Desde dashboards analíticos hasta arquitecturas cloud complejas.
        </p>
        <ul class="space-y-4 mb-10">
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">check_circle</span>
            <span class="font-semibold" data-i18n="solutions.feature1">Arquitecturas de microservicios</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">check_circle</span>
            <span class="font-semibold" data-i18n="solutions.feature2">Diseño UX/UI centrado en conversión</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">check_circle</span>
            <span class="font-semibold" data-i18n="solutions.feature3">Seguridad y encriptación bancaria</span>
          </li>
        </ul>
        <button class="bg-primary/10 text-primary hover:bg-primary hover:text-white border border-primary/20 px-8 py-3 rounded-lg font-bold transition-all" data-i18n="solutions.cta">
          Solicitar auditoría
        </button>
      </div>
      <div class="order-1 lg:order-2 relative h-[500px] w-full flex items-center justify-center perspective-1000">
        <!-- Abstract Animated Container -->
        <div class="relative w-full max-w-lg aspect-square">
          
          <!-- Background Glow -->
          <div class="absolute inset-0 bg-primary/20 dark:bg-primary/10 blur-[100px] rounded-full animate-pulse"></div>

          <!-- Connecting Lines (SVG background) -->
          <svg class="absolute inset-0 w-full h-full opacity-20 dark:opacity-30" viewBox="0 0 100 100">
            <path d="M 50 20 L 80 50 L 50 80 L 20 50 Z" fill="none" class="stroke-primary" stroke-width="0.5" stroke-dasharray="2,2">
              <animate attributeName="stroke-dashoffset" values="4;0" dur="2s" repeatCount="indefinite" />
            </path>
            <path d="M 50 10 L 90 50 L 50 90 L 10 50 Z" fill="none" class="stroke-accent" stroke-width="0.3" stroke-dasharray="4,4">
              <animate attributeName="stroke-dashoffset" values="0;8" dur="3s" repeatCount="indefinite" />
            </path>
          </svg>

          <!-- Floating Node 1: Microservices (Top Right) -->
          <div class="absolute top-10 right-10 w-24 h-24 bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700 flex flex-col items-center justify-center gap-2 animate-[float_4s_ease-in-out_infinite] z-20">
            <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent">
              <span class="material-symbols-outlined absolute animate-ping opacity-75">dns</span>
              <span class="material-symbols-outlined relative">dns</span>
            </div>
            <span class="text-[10px] font-bold text-slate-500 uppercase" data-i18n="solutions.nodeCloud">Nube</span>
          </div>

          <!-- Floating Node 2: Security (Bottom Left) -->
          <div class="absolute bottom-10 left-10 w-24 h-24 bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700 flex flex-col items-center justify-center gap-2 animate-[float_5s_ease-in-out_infinite_1s] z-20">
            <div class="w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center text-green-500">
              <span class="material-symbols-outlined">shield_locked</span>
            </div>
            <span class="text-[10px] font-bold text-slate-500 uppercase" data-i18n="solutions.nodeSecure">Seguro</span>
          </div>

          <!-- Central Node: UX/UI Dashboard Mockup -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-48 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/50 dark:border-slate-700/50 overflow-hidden z-30 animate-[float_6s_ease-in-out_infinite_2s]">
            <!-- Mac-style Window header -->
            <div class="h-6 bg-slate-100 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 flex items-center px-3 gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-amber-400"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400"></div>
            </div>
            <!-- Mock Dashboard Content -->
            <div class="p-4 space-y-3">
              <div class="h-4 w-1/3 bg-slate-200 dark:bg-slate-700 rounded-md"></div>
              <div class="flex gap-2">
                <div class="h-20 w-1/2 bg-primary/20 dark:bg-primary/30 rounded-lg relative overflow-hidden">
                   <div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-primary/50 to-transparent"></div>
                </div>
                <div class="h-20 w-1/2 bg-accent/20 dark:bg-accent/30 rounded-lg relative overflow-hidden">
                  <div class="absolute bottom-0 left-0 right-0 h-3/4 bg-gradient-to-t from-accent/50 to-transparent"></div>
                </div>
              </div>
              <div class="space-y-2">
                <div class="h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <div class="h-full bg-primary w-3/4 animate-[pulse_2s_ease-in-out_infinite]"></div>
                </div>
                <div class="h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <div class="h-full bg-green-500 w-1/2 animate-[pulse_3s_ease-in-out_infinite]"></div>
                </div>
              </div>
            </div>
            
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-primary/0 hover:bg-primary/5 transition-colors duration-300 flex items-center justify-center opacity-0 hover:opacity-100 cursor-default">
              <span class="bg-white dark:bg-slate-800 text-primary px-3 py-1 text-xs font-bold rounded-full shadow-lg" data-i18n="solutions.overlay">UX/UI optimizado</span>
            </div>
          </div>

          <!-- Decorative Code Block (Bottom Right) -->
           <div class="absolute bottom-20 right-0 w-32 bg-slate-900 border border-slate-700 rounded-lg p-3 shadow-lg z-10 animate-[float_4.5s_ease-in-out_infinite_0.5s] origin-bottom-right rotate-6 opacity-80 backdrop-blur-md">
            <div class="space-y-1.5">
              <div class="h-1.5 w-full bg-pink-500/50 rounded-full"></div>
              <div class="h-1.5 w-4/5 bg-blue-500/50 rounded-full"></div>
              <div class="h-1.5 w-5/6 bg-green-500/50 rounded-full"></div>
              <div class="h-1.5 w-2/3 bg-yellow-500/50 rounded-full"></div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
</style>