                <h4 class="text-2xl font-extrabold text-slate-900 dark:text-white" data-i18n="products.qrpass.panelTitle">Accesos rápidos y seguros</h4>
              </div>
              <div class="md:col-span-8 text-slate-600 dark:text-slate-300 leading-relaxed">
