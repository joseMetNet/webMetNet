---
// Stitch Generated Products Component
---

<section class="py-24 bg-slate-50 dark:bg-slate-900/30 relative" id="products">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div>
        <h2 class="text-4xl font-extrabold text-slate-900 dark:text-white mb-2">
          Internal Products
        </h2>
        <p class="text-slate-500">
          Soluciones propietarias que aceleran negocios.
        </p>
      </div>
      <a class="text-primary font-bold flex items-center gap-2 group" href="#">
        View all products
        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Product 1 -->
      <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group">
        <div class="w-14 h-14 bg-slate-50 dark:bg-slate-700 rounded-xl flex items-center justify-center mb-6 text-primary">
          <span class="material-symbols-outlined text-3xl">description</span>
        </div>
        <h3 class="text-xl font-bold mb-2">Documatic</h3>
        <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">
          Automatización inteligente de documentos con IA y procesamiento en lenguaje natural.
        </p>
        <a class="text-primary font-bold text-sm inline-flex items-center gap-1 group/link" href="#">
          Learn more
          <span class="material-symbols-outlined text-sm group-hover/link:translate-x-0.5 transition-transform">chevron_right</span>
        </a>
      </div>
      <!-- Product 2 -->
      <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group">
        <div class="w-14 h-14 bg-slate-50 dark:bg-slate-700 rounded-xl flex items-center justify-center mb-6 text-accent">
          <span class="material-symbols-outlined text-3xl">qr_code_2</span>
        </div>
        <h3 class="text-xl font-bold mb-2">QRPass</h3>
        <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">
          Control de acceso seguro y sin contacto para eventos y oficinas corporativas.
        </p>
        <a class="text-primary font-bold text-sm inline-flex items-center gap-1 group/link" href="#">
          Learn more
          <span class="material-symbols-outlined text-sm group-hover/link:translate-x-0.5 transition-transform">chevron_right</span>
        </a>
      </div>
      <!-- Product 3 -->
      <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group">
        <div class="w-14 h-14 bg-slate-50 dark:bg-slate-700 rounded-xl flex items-center justify-center mb-6 text-green-500">
          <span class="material-symbols-outlined text-3xl">engineering</span>
        </div>
        <h3 class="text-xl font-bold mb-2">ERP EnObra</h3>
        <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm">
          Gestión integral para proyectos de construcción e ingeniería civil de gran escala.
        </p>
        <a class="text-primary font-bold text-sm inline-flex items-center gap-1 group/link" href="#">
          Learn more
          <span class="material-symbols-outlined text-sm group-hover/link:translate-x-0.5 transition-transform">chevron_right</span>
        </a>
      </div>
    </div>
  </div>
</section>
