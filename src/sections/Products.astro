---
// Stitch Generated Products Component
---

<section class="py-24 bg-slate-50 dark:bg-slate-900/30 relative" id="products">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div>
        <h2 class="text-4xl font-extrabold text-slate-900 dark:text-white mb-2" data-i18n="products.title">
          Productos internos
        </h2>
        <p class="text-slate-500" data-i18n="products.subtitle">
          Soluciones propietarias que aceleran negocios.
        </p>
      </div>
      <a class="text-primary font-bold flex items-center gap-2 group" href="#contact">
        <span data-i18n="products.cta">Contactar ahora</span>
        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-4 md:gap-y-8" data-products-grid>
      <!-- Product 1 -->
      <div class="contents">
        <button class="product-card primary bg-white dark:bg-slate-800 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group text-left h-full md:order-1" type="button" data-product-card="documatic" aria-expanded="false" aria-controls="product-panel-documatic">
          <div class="w-14 h-14 bg-slate-50 dark:bg-slate-700 rounded-xl flex items-center justify-center mb-6 text-primary">
            <span class="material-symbols-outlined text-3xl">description</span>
          </div>
          <h3 class="text-xl font-bold mb-2">Documatic</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-6 text-sm" data-i18n="products.documatic.card">
            Automatización inteligente de documentos con IA y procesamiento en lenguaje natural.
          </p>
          <div class="text-primary font-bold text-sm inline-flex items-center gap-1 group/link">
            <span data-i18n="products.learnMore">Ver más</span>
            <span class="material-symbols-outlined text-sm group-hover/link:translate-x-0.5 transition-transform">chevron_right</span>
          </div>
          <div class="product-active-bar mt-6 h-1 w-12 rounded-full bg-primary opacity-0 transition-opacity duration-300"></div>
        </button>
        <div id="product-panel-documatic" class="product-panel md:col-span-2 lg:col-span-4 md:order-2 hidden" data-product-panel="documatic" aria-hidden="true">
          <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8 my-4">
            <div class="grid md:grid-cols-12 gap-6 items-start">
              <div class="md:col-span-4">
                <p class="text-xs font-bold uppercase tracking-widest text-primary mb-2">Documatic</p>
                <h4 class="text-2xl font-extrabold text-slate-900 dark:text-white" data-i18n="products.documatic.panelTitle">Gestión documental centralizada</h4>
              </div>
              <div class="md:col-span-8 text-slate-600 dark:text-slate-300 leading-relaxed">
                <p data-i18n="products.documatic.lead">Documatic centraliza la generación, firma y almacenamiento de documentos en una sola plataforma.</p>
                <ul class="mt-4 space-y-2 text-sm">
                  <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-primary"></span><span data-i18n="products.documatic.bullets.0">Organiza la información por tipo de persona o institución.</span></li>
                  <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-primary"></span><span data-i18n="products.documatic.bullets.1">Controla vencimientos con alertas y trazabilidad completa.</span></li>
                  <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-primary"></span><span data-i18n="products.documatic.bullets.2">Asegura eficiencia, cumplimiento y auditoría continua.</span></li>
                </ul>
                <div class="mt-5 flex flex-wrap items-center gap-2 text-xs uppercase tracking-widest text-slate-400">
                  <span class="px-3 py-1 rounded-full border border-slate-300/40 dark:border-slate-700" data-i18n="products.documatic.flow.0">Genera</span>
                  <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  <span class="px-3 py-1 rounded-full border border-slate-300/40 dark:border-slate-700" data-i18n="products.documatic.flow.1">Firma</span>
                  <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  <span class="px-3 py-1 rounded-full border border-slate-300/40 dark:border-slate-700" data-i18n="products.documatic.flow.2">Archiva</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Product 2 -->
      <div class="contents">
        <button class="product-card accent bg-white dark:bg-slate-800 p-8 rounded-2xl border border-slate-100 dark:border-slate-700 hover:border-primary transition-all group text-left h-full md:order-1" type="button" data-product-card="qrpass" aria-expanded="false" aria-controls="product-panel-qrpass">
          <div class="w-14 h-14 bg-slate-50 dark:bg-slate-700 rounded-xl flex items-center justify-center mb-6 text-accent">
            <span class="material-symbols-outlined text-3xl">qr_code_2</span>
