---
// Stitch Generated Contact Component
---

<section class="py-24 bg-background-dark text-white relative" id="contact">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <h2 class="text-4xl font-extrabold mb-6">
          Hablemos de tu próximo proyecto
        </h2>
        <p class="text-slate-400 text-lg mb-10 leading-relaxed">
          Cuéntanos tus desafíos y nosotros te ayudaremos a construir la solución. Respondemos en menos de 24 horas hábiles.
        </p>
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center text-primary">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <div>
              <p class="text-xs font-bold text-slate-500 uppercase">
                Email us
              </p>
              <p class="font-semibold">hello@metnet.tech</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center text-accent">
              <span class="material-symbols-outlined">call</span>
            </div>
            <div>
              <p class="text-xs font-bold text-slate-500 uppercase">
                Call us
              </p>
              <p class="font-semibold">+1 (555) 000-1234</p>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-slate-800/50 p-8 md:p-10 rounded-2xl border border-slate-700">
        <form action="#" class="space-y-5">
          <div class="grid md:grid-cols-2 gap-5">
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-400">Nombre</label>
              <input class="w-full bg-slate-900 border-slate-700 rounded-lg py-3 focus:ring-primary focus:border-primary text-white" placeholder="John Doe" type="text" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-400">Compañía</label>
              <input class="w-full bg-slate-900 border-slate-700 rounded-lg py-3 focus:ring-primary focus:border-primary text-white" placeholder="Acme Inc." type="text" />
            </div>
          </div>
          <div class="grid md:grid-cols-2 gap-5">
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-400">Teléfono</label>
              <input class="w-full bg-slate-900 border-slate-700 rounded-lg py-3 focus:ring-primary focus:border-primary text-white" placeholder="+1 234 567" type="tel" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-400">Email</label>
              <input class="w-full bg-slate-900 border-slate-700 rounded-lg py-3 focus:ring-primary focus:border-primary text-white" placeholder="john@company.com" type="email" />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-bold text-slate-400">Mensaje</label>
            <textarea class="w-full bg-slate-900 border-slate-700 rounded-lg py-3 focus:ring-primary focus:border-primary text-white" placeholder="¿En qué podemos ayudarte?" rows="4"></textarea>
          </div>
          <button class="w-full bg-primary hover:bg-primary/90 text-white font-black py-4 rounded-lg transition-all transform hover:translate-y-[-2px] shadow-lg shadow-primary/20 uppercase tracking-widest text-sm">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
