---
// Stitch Generated Contact Component
---

<section class="py-24 bg-background-light dark:bg-background-dark text-slate-900 dark:text-white relative overflow-hidden transition-colors duration-300" id="contact">
  <!-- Subtle Background Decorative Elements -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-6 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-600 dark:from-white dark:via-slate-200 dark:to-slate-400 bg-clip-text text-transparent" data-i18n="contact.title">
        Hablemos de tu próximo proyecto
      </h2>
      <p class="text-slate-600 dark:text-slate-400 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto" data-i18n="contact.desc">
        Cuéntanos tus desafíos y nosotros te ayudaremos a construir la solución. Nuestra promesa es responder lo más inmediato posible: ¡estarás hablando con una persona real en poco tiempo!
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- Email CTA Card -->
      <a 
        href="mailto:contact@metnet.co" 
        class="group relative bg-white/70 dark:bg-slate-900/50 backdrop-blur-md p-10 rounded-3xl border border-slate-200 dark:border-slate-800 hover:border-primary/50 transition-all duration-500 hover:shadow-2xl hover:shadow-primary/10 flex flex-col items-center text-center overflow-hidden shadow-sm"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="w-20 h-20 rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-primary mb-8 group-hover:scale-110 group-hover:bg-primary group-hover:text-white transition-all duration-500 shadow-lg">
          <span class="material-symbols-outlined text-4xl">mail</span>
        </div>
        
        <h3 class="text-2xl font-bold mb-3 text-slate-900 dark:text-white" data-i18n="contact.emailLabel">Escríbenos</h3>
        <p class="text-slate-600 dark:text-slate-400 font-medium mb-8">contact@metnet.co</p>
        
        <span class="inline-flex items-center gap-2 bg-primary text-white px-8 py-3.5 rounded-xl font-bold transition-all transform group-hover:scale-105 shadow-lg shadow-primary/20 uppercase tracking-widest text-xs" data-i18n="contact.ctaEmail">
          Enviar Correo
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </span>
      </a>

      <!-- WhatsApp CTA Card -->
      <a 
        href="https://wa.me/573127888573" 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative bg-white/70 dark:bg-slate-900/50 backdrop-blur-md p-10 rounded-3xl border border-slate-200 dark:border-slate-800 hover:border-emerald-500/50 transition-all duration-500 hover:shadow-2xl hover:shadow-emerald-500/10 flex flex-col items-center text-center overflow-hidden shadow-sm"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="w-20 h-20 rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-emerald-500 mb-8 group-hover:scale-110 group-hover:bg-emerald-500 group-hover:text-white transition-all duration-500 shadow-lg">
          <svg class="w-10 h-10 fill-current" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        
        <h3 class="text-2xl font-bold mb-3 text-slate-900 dark:text-white" data-i18n="contact.phoneLabel">WhatsApp</h3>
        <p class="text-slate-600 dark:text-slate-400 font-medium mb-8">+57 312 788 8573</p>
        
        <span class="inline-flex items-center gap-2 bg-emerald-500 text-white px-8 py-3.5 rounded-xl font-bold transition-all transform group-hover:scale-105 shadow-lg shadow-emerald-500/20 uppercase tracking-widest text-xs" data-i18n="contact.ctaWhatsapp">
          Escribir por WhatsApp
          <span class="material-symbols-outlined text-sm">chat</span>
        </span>
      </a>
    </div>
  </div>
</section>
