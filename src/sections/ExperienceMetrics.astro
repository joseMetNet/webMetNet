---
// Stitch Generated ExperienceMetrics Component
---

<section class="py-20 bg-slate-900 text-white relative">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      <div class="space-y-2">
        <p class="text-5xl font-black text-primary">140+</p>
        <p class="text-slate-400 font-bold uppercase tracking-widest text-sm">
          MVPs built
        </p>
      </div>
      <div class="space-y-2 border-y md:border-y-0 md:border-x border-slate-800 py-12 md:py-0">
        <p class="text-5xl font-black text-accent">7+</p>
        <p class="text-slate-400 font-bold uppercase tracking-widest text-sm">
          Years experience
        </p>
      </div>
      <div class="space-y-2">
        <p class="text-5xl font-black text-primary">720K</p>
        <p class="text-slate-400 font-bold uppercase tracking-widest text-sm">
          Dev hours
        </p>
      </div>
    </div>
  </div>
</section>
